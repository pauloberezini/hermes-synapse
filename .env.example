# ====================================================================
# Hermes (Jarvis): Environment Configuration Template
# Copy this file to .env and fill in your keys.
# ====================================================================

# ── LLM PROVIDER ─────────────────────────────────────────────────────
# Ollama is the default and needs no API key. OpenRouter and generic
# OpenAI-compatible endpoints remain available as optional providers.
# Provider: ollama | openrouter | openai_compatible
LLM_PROVIDER=ollama
# Native Ollama server (without /api or /v1). In Docker Compose this is
# overridden to http://ollama:11434.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Production containers can pin the provider endpoint so a stale dashboard
# setting cannot replace the Docker service address with localhost.
LLM_LOCK_PROVIDER_ENDPOINT=false
# Optional bearer token for a protected remote Ollama endpoint. Leave empty for
# the standard local/Docker server.
OLLAMA_API_KEY=
LLM_MODEL=hf.co/unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q4_K_M

# Optional cloud/OpenAI-compatible fallback.
LLM_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fast local-model defaults. These keep Telegram responsive when using Ollama
# or another local OpenAI-compatible backend.
LLM_FAST_MODE=false
LLM_MAX_HISTORY_MESSAGES=6
LLM_MAX_TOKENS=2048
LLM_TOOL_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
# Provider resilience. Retries apply only to transient failures and are disabled
# after a tool may have produced side effects.
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=1
LLM_MAX_TOOL_ITERATIONS=8
RAG_AUTO_CONTEXT=false
MEMORY_ENABLED=true
MEMORY_AUTO_SAVE=true
MEMORY_MAX_ITEMS=4

# ── OPTIONAL: Ollama-specific settings ────────────────────────────────
# Context window size passed to Ollama as `num_ctx`.  Increase if your
# system prompt + history is large. The default below targets a 2x RTX 3090,
# 96 GB RAM host; lower it to 65536 or 131072 if another workload needs VRAM.
OLLAMA_NUM_CTX=262144
# How long a model remains loaded: 5m, 1h, -1 (forever), or 0 (unload).
OLLAMA_KEEP_ALIVE=-1
# false | true | low | medium | high (levels require a supporting model).
OLLAMA_THINK=true

# Ollama server tuning used by the bundled Compose service. Flash attention
# plus q8_0 KV cache keeps a very large context substantially more practical.
OLLAMA_CONTEXT_LENGTH=262144
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
CUDA_VISIBLE_DEVICES=0,1

# ── OPTIONAL: Per-agent model overrides ──────────────────────────────
# Override the model used by each specialized agent role.
# Falls back to LLM_MODEL if not set.
#
# Leave blank to use LLM_MODEL. Set installed Ollama model names here only when
# a specialized role genuinely benefits from a different local model.
AGENT_MODEL_RESEARCH=
AGENT_MODEL_CODE=
AGENT_MODEL_ANALYST=
AGENT_MODEL_PLANNER=
# keyword/false/off/fast = no extra LLM router call; auto = classifier LLM call.
COMPLEXITY_ROUTING=keyword

# ── SYSTEM BACKEND ───────────────────────────────────────────────────
PORT=8000

# ── TELEGRAM INTERFACE ───────────────────────────────────────────────
# Agents: all agents are accessible via Telegram
# Create a bot via @BotFather → https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your numeric chat ID via @userinfobot → https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Authorized admin user ID(s) that the bot will respond to (comma-separated if multiple; all others are blocked at code level)
TELEGRAM_ADMIN_ID=your_telegram_admin_id_here

# ── LOCAL VOICE ASSISTANT ───────────────────────────────────────────
# Free local speech-to-text powered by faster-whisper.
# First run downloads the selected model. Use "base" for weaker CPUs,
# "small" for a good default, "medium" if you have more RAM/GPU.
VOICE_STT_ENABLED=true
VOICE_STT_MODEL=small
VOICE_STT_DEVICE=cpu
VOICE_STT_COMPUTE_TYPE=int8
VOICE_STT_LANGUAGE=ru
VOICE_STT_VAD_FILTER=true
VOICE_MAX_UPLOAD_MB=25

# Local TTS is opt-in: no engine or voice model is downloaded automatically.
# Review the engine and selected voice model licenses before enabling.
# Supported providers: auto, piper, rhvoice.
VOICE_TTS_ENABLED=false
VOICE_TTS_PROVIDER=auto
VOICE_TTS_VOICE=
VOICE_TTS_PIPER_BINARY=piper
VOICE_TTS_PIPER_MODEL=
VOICE_TTS_RHVOICE_BINARY=RHVoice-test
VOICE_TTS_TIMEOUT_SECONDS=30
VOICE_TTS_MAX_CHARS=4000

# ── SEARCH AGENT & FOOTBALL ANALYST ─────────────────────────────────
# Skill: web_search — powers web search, news, football results
# Google Serper — free tier: 2,500 queries/month → https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── SEARCH AGENT: WEATHER ────────────────────────────────────────────
# Skill: web_search (weather sub-feature)
# OpenWeatherMap — free tier: 1,000 calls/day → https://home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ── DAILY PLANNER: TODOIST ───────────────────────────────────────────
# Skill: todoist_sync
# Todoist → Settings → Integrations → Developer
# → https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_token_here

# ── DAILY PLANNER: GOOGLE CALENDAR ───────────────────────────────────
# Skill: google_calendar — OAuth2 setup (one-time, on host machine)
# 1. Create Desktop OAuth 2.0 credentials at:
#    https://console.cloud.google.com/apis/credentials
# 2. Download the JSON and place it in the project root as client_secret_*.json
# 3. Run once on your host: python3 backend/google_auth.py
#    This generates google_token.json which is volume-mounted into Docker.

# ── OBSIDIAN RAG SKILL ───────────────────────────────────────────────
# Skill: obsidian_rag — local knowledge base search & sync
# Install "Local REST API" plugin in Obsidian:
# → https://github.com/coddingtonbear/obsidian-local-rest-api
OBSIDIAN_API_KEY=your_obsidian_local_rest_api_key_here
# In hermes-web/docker-compose.yml, backend overrides this to "obsidian"
# so it can reach the Obsidian container over the Docker network.
OBSIDIAN_HOST=obsidian
OBSIDIAN_PORT=27124
OBSIDIAN_VAULT_PATH=/config/vaults/Hermes

# Web UI credentials for the Obsidian container.
# Dashboard URL: https://127.0.0.1:3001
# Note: Docker Compose interpolation reads shell variables or hermes-web/.env,
# not env_file values from src/.env. Defaults are set in docker-compose.yml.
OBSIDIAN_WEB_USER=hermes
OBSIDIAN_WEB_PASSWORD=change_me

# ── MARKET DATA PROVIDER ─────────────────────────────────────────────
# Skill: market_monitor — real-time price alerts for crypto & stocks
#
# MARKET_DATA_PROVIDER controls which backend fetches prices.
# Options:
#   http    → Default. CoinGecko (crypto) + Yahoo Finance (stocks).
#             Zero config, zero API keys. Works out of the box.
#   ccxt    → CCXT library. Real-time crypto via any supported exchange.
#             Requires: uv sync --group market-ccxt
#   alpaca  → Alpaca Market Data API. Real-time US equities.
#             Requires: uv sync --group market-alpaca + free Alpaca account.
#
MARKET_DATA_PROVIDER=http

# ── CCXT options (only used when MARKET_DATA_PROVIDER=ccxt) ──────────
# CCXT_EXCHANGE=binance        # Exchange ID. See: https://github.com/ccxt/ccxt/wiki/Exchange-Markets
# CCXT_QUOTE=USDT              # Quote currency for pairs (default: USDT)

# ── Alpaca options (only used when MARKET_DATA_PROVIDER=alpaca) ──────
# ALPACA_API_KEY=your_alpaca_key_here
# ALPACA_API_SECRET=your_alpaca_secret_here
# Sign up (free paper-trading account): https://alpaca.markets

# ── DATABASE (OPTIONAL) ──────────────────────────────────────────────
# Default: SQLite with WAL mode enabled automatically.
# No configuration needed for local development — zero-friction onboarding.
#
# WAL mode benefits (enabled automatically in SQLite):
#   - Eliminates "database is locked" errors under concurrent load
#   - Readers never block writers; writers never block readers
#   - busy_timeout=5000ms prevents crashes on high-concurrency scenarios
#
# To switch to PostgreSQL (optional, for production):
#   1. Install deps:  uv sync --group postgres
#   2. Uncomment and set:
# DATABASE_URL=postgresql://user:password@localhost:5432/hermes
#
# Any SQLAlchemy-compatible URL works (e.g. postgresql+asyncpg://)
# Community contributors: leave this unset — SQLite works out of the box.

# ── AUTONOMY AND PROJECT MEMORY ─────────────────────────────────────
# Docker Compose mounts this repository read-only at /workspace.
# The index stores paths, symbols and imports, never source contents.
PROJECT_MEMORY_AUTO_INDEX=true
AUTONOMY_PROJECT_CONTEXT=true
AUTONOMY_INDEX_MAX_FILES=4000
AUTONOMY_INDEX_MAX_FILE_BYTES=750000
# Exact allowlisted recipes only. Each installation still requires Control Plane approval.
AUTONOMY_INSTALL_ENABLED=false
AUTONOMY_CAPABILITY_ROOT=/app/backend/data/capabilities
AUTONOMY_INSTALL_TIMEOUT_SECONDS=300
# MCP secrets are referenced by name and remain outside mcp_config.json.
# STATIC_BEARER_TOKEN=replace_with_secret_in_the_real_env_only
