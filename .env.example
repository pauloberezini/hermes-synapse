# ====================================================================
# Hermes (Jarvis): Environment Configuration Template
# Copy this file to .env and configure your keys and options
# ====================================================================

# --- LLM / OpenRouter Config ---
LLM_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-2.5-flash

# Model overrides for specialized agent roles (optional)
AGENT_MODEL_RESEARCH=google/gemini-2.5-flash
AGENT_MODEL_CODE=google/gemini-2.5-flash
AGENT_MODEL_ANALYST=google/gemini-2.5-flash
AGENT_MODEL_PLANNER=google/gemini-2.5-flash
COMPLEXITY_ROUTING=false

# --- Telegram Bot Config ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your numeric Telegram user/chat ID (can be fetched via @userinfobot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- System Backend Settings ---
PORT=8000

# --- Optional API Keys for Skills ---
# Get weather API key at https://weatherstack.com or openweathermap.org
OPENWEATHERMAP_API_KEY=your_weather_api_key_here

# Google search tool: get Serper key at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Todoist integration: get API token in Settings -> Integrations -> Developer API token
TODOIST_API_TOKEN=your_todoist_token_here

# --- Obsidian Integration (Local Knowledge Base) ---
# Settings to connect with the Obsidian "Local REST API" plugin
OBSIDIAN_API_KEY=your_obsidian_local_rest_api_key_here
OBSIDIAN_HOST=host.docker.internal
OBSIDIAN_PORT=27124
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
